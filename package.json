{
    "name": "vite-spa-plain-tsx",
    "description": "Frontend vanilla TypeScript based on Vite with support of TSX",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite",
        "dev+mock": "concurrently --kill-others --handle-input --names web,api 'bun:dev' 'bun:mock:port'",
        "build": "bun run clean && tsc && vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "playwright": "bunx playwright test",
        "playwright:ui": "bunx playwright test --ui",
        "inspect": "npx serve .vite-inspect",
        "prepare": "husky",
        "format": "bunx --bun @biomejs/biome format --write .",
        "lint": "bunx --bun @biomejs/biome check --write",
        "clean": "rimraf ./dist",
        "mock": "bunx json-server test/mocks/data.json",
        "mock:port": "bun test/start-mock-server.ts",
        "gen:doc": "npx typedoc --options typedoc.json"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.9",
        "@playwright/test": "^1.58.2",
        "@shipgirl/typedoc-plugin-versions": "^0.3.2",
        "@tailwindcss/vite": "^4.2.2",
        "@testing-library/dom": "^10.4.1",
        "@types/bun": "^1.3.11",
        "@types/lodash-es": "^4.17.12",
        "@types/node": "^25.5.0",
        "@vitejs/devtools": "^0.1.11",
        "@vitest/ui": "^4.1.2",
        "concurrently": "^9.2.1",
        "global-jsdom": "^29.0.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "json-server": "^1.0.0-beta.15",
        "jsx-dom": "^8.1.6",
        "lint-staged": "^16.4.0",
        "lodash-es": "^4.17.23",
        "msw": "^2.12.14",
        "rimraf": "^6.1.3",
        "tailwindcss": "^4.2.2",
        "tinyexec": "^1.0.4",
        "typedoc": "^0.28.18",
        "typedoc-plugin-coverage": "^4.0.2",
        "typedoc-theme-hierarchy": "^6.0.0",
        "typescript": "~6.0.2",
        "unplugin-turbo-console": "^2.3.0",
        "vite": "^8.0.3",
        "vite-plugin-inspect": "^12.0.0-beta.1",
        "vitest": "^4.1.2"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MansourM61/vite-spa-plain-tsx.git"
    },
    "files": ["dist"],
    "lint-staged": {
        "**/*.{css,html,js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
    },
    "packageManager": "bun@1.3.6"
}
