{
    "compilerOptions": {
        "outDir": "dist",
        "target": "ES2023",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "types": ["vite/client", "unplugin-turbo-console/client", "bun"],
        "skipLibCheck": true,
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "allowUnusedLabels": false,
        "noUncheckedSideEffectImports": true,
        "noFallthroughCasesInSwitch": true,
        "allowUnreachableCode": false,
        "noUncheckedIndexedAccess": true,
        "noPropertyAccessFromIndexSignature": true,
        "erasableSyntaxOnly": true, // avoids using types such as `enum` that cannot be safely removed from the code without breaking it
        "noImplicitOverride": true,
        "noErrorTruncation": false,
        "exactOptionalPropertyTypes": false,
        "allowJs": true,
        "checkJs": false, // for each file to be checked, add `// @ts-check` as the first line
        /* Path aliases */
        "paths": {
            "@/*": ["./*"],
            "@src/*": ["./src/*"],
            "@lib/*": ["./src/lib/*"],
            "@components/*": ["./src/components/*"]
        },
        /* JSX/TSX support */
        "jsx": "preserve", // keep the JSX syntax so that `jsx-dom` can convert it.
        "jsxImportSource": "jsx-dom" // imports the types, functions, etc
    },
    "files": ["vite.config.ts", "./src/main.ts"],
    "include": ["**/*.ts", "**/*.tsx"]
}
